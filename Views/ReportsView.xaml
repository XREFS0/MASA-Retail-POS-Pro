<UserControl x:Class="MASA.RetailPOS.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
            <materialDesign:PackIcon Kind="ChartBoxOutline" Width="32" Height="32" Foreground="#8C52FF" VerticalAlignment="Center"/>
            <TextBlock Text="التقارير والإحصائيات" FontSize="28" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center" Foreground="White"/>
            <Button Command="{Binding LoadStatisticsCommand}" Style="{StaticResource MaterialDesignIconButton}" Margin="20,0,0,0" ToolTip="تحديث البيانات">
                <materialDesign:PackIcon Kind="Refresh" Foreground="#00E676"/>
            </Button>
        </StackPanel>

        <WrapPanel Grid.Row="1" Orientation="Horizontal">
            <!-- Sales Card -->
            <Border Background="#1E1E2F" CornerRadius="15" Padding="20" Width="250" Height="150" Margin="0,0,20,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashMultiple" Width="24" Height="24" Foreground="#00E676" VerticalAlignment="Center"/>
                        <TextBlock Text="إجمالي المبيعات" FontSize="18" Foreground="#A0A0B0" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalSales, StringFormat=C}" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Products Card -->
            <Border Background="#1E1E2F" CornerRadius="15" Padding="20" Width="250" Height="150" Margin="0,0,20,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PackageVariant" Width="24" Height="24" Foreground="#29B6F6" VerticalAlignment="Center"/>
                        <TextBlock Text="عدد المنتجات" FontSize="18" Foreground="#A0A0B0" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalProducts}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Customers Card -->
            <Border Background="#1E1E2F" CornerRadius="15" Padding="20" Width="250" Height="150" Margin="0,0,20,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24" Foreground="#FFB300" VerticalAlignment="Center"/>
                        <TextBlock Text="عدد العملاء" FontSize="18" Foreground="#A0A0B0" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalCustomers}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Suppliers Card -->
            <Border Background="#1E1E2F" CornerRadius="15" Padding="20" Width="250" Height="150" Margin="0,0,20,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TruckDeliveryOutline" Width="24" Height="24" Foreground="#FF5252" VerticalAlignment="Center"/>
                        <TextBlock Text="عدد الموردين" FontSize="18" Foreground="#A0A0B0" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalSuppliers}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </WrapPanel>
    </Grid>
</UserControl>
