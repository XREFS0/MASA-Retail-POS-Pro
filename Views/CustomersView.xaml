<UserControl x:Class="MASA.RetailPOS.App.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: DataGrid -->
        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="AccountGroup" Width="40" Height="40" Foreground="#8C52FF" VerticalAlignment="Center"/>
                <TextBlock Text="إدارة العملاء (CRM)" FontSize="32" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center" Foreground="White"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="30,0,0,0" Background="#00E676" BorderBrush="#00E676" Foreground="White" Height="45" Command="{Binding AddNewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock Text="إضافة عميل جديد" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Customers}" AutoGenerateColumns="False" CanUserAddRows="False"
                      Background="#1E1E2F" RowBackground="#252538" AlternatingRowBackground="#1E1E2F"
                      Foreground="White" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="None" SelectionMode="Single">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D2D42"/>
                        <Setter Property="Foreground" Value="#A0A0B0"/>
                        <Setter Property="Padding" Value="20,15"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#444466"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="20,15"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#8C52FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="كود" Binding="{Binding Id}" Width="100"/>
                    <DataGridTextColumn Header="اسم العميل" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding Phone}" Width="1.5*"/>
                    <DataGridTextColumn Header="الديون المتأخرة" Binding="{Binding TotalDebt, StringFormat=C}" Width="1.5*"/>
                    <DataGridTextColumn Header="نقاط الولاء" Binding="{Binding LoyaltyPoints}" Width="1.5*"/>
                    <DataGridTemplateColumn Header="إجراءات" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="تعديل" 
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Foreground="#29B6F6" Width="35" Height="35" Margin="0,0,10,0">
                                        <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="حذف" 
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Foreground="#FF5252" Width="35" Height="35">
                                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Right Column: Edit Panel -->
        <Border Grid.Column="1" Width="400" Background="#1E1E2F" CornerRadius="10" Padding="30" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="تفاصيل العميل" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,30"/>

                <TextBox materialDesign:HintAssist.Hint="اسم العميل" Text="{Binding SelectedCustomer.Name, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White" FontSize="16" Margin="0,0,0,25"/>

                <TextBox materialDesign:HintAssist.Hint="رقم الهاتف" Text="{Binding SelectedCustomer.Phone, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White" FontSize="16" Margin="0,0,0,25"/>

                <TextBox materialDesign:HintAssist.Hint="البريد الإلكتروني" Text="{Binding SelectedCustomer.Email, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White" FontSize="16" Margin="0,0,0,25"/>
                         
                <TextBox materialDesign:HintAssist.Hint="الديون المتأخرة" Text="{Binding SelectedCustomer.TotalDebt, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White" FontSize="16" Margin="0,0,0,25"/>

                <TextBox materialDesign:HintAssist.Hint="نقاط الولاء" Text="{Binding SelectedCustomer.LoyaltyPoints, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White" FontSize="16" Margin="0,0,0,40"/>

                <Button Content="حفظ البيانات" Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="#00E676" BorderBrush="#00E676" Foreground="White" Height="50" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                <Button Content="إلغاء" Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#FF5252" BorderBrush="#FF5252" Height="50" FontSize="18" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
