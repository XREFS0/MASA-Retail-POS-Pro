<UserControl x:Class="MASA.RetailPOS.App.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             TextElement.FontWeight="Regular"
             TextElement.FontSize="14"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="Auto"
             FontFamily="{DynamicResource MaterialDesignFont}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <!-- Cart/Invoice Area -->
            <ColumnDefinition Width="*"/>
            <!-- Products Grid Area -->
        </Grid.ColumnDefinitions>

        <!-- Right Side (which is left in RTL): Cart / Current Invoice -->
        <Border Grid.Column="0" Background="#1E1E2F" CornerRadius="10" Margin="0,0,10,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Customer Selection & Controls -->
                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource MaterialDesignIconButton}" ToolTip="Clear Cart" Foreground="#FF5252"
                                Command="{Binding ClearCartCommand}">
                            <materialDesign:PackIcon Kind="TrashCanOutline" />
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}" ToolTip="Discount"
                                Command="{Binding ToggleDiscountCommand}">
                            <materialDesign:PackIcon Kind="Percent" />
                        </Button>
                        <ComboBox Grid.Column="2" materialDesign:HintAssist.Hint="العميل" Margin="10,0" VerticalAlignment="Center"
                                  ItemsSource="{Binding Customers}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedCustomer}">
                        </ComboBox>
                        <Button Grid.Column="3" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Width="32" Height="32" Background="#8C52FF" BorderBrush="#8C52FF"
                                Command="{Binding ToggleAddCustomerCommand}">
                            <materialDesign:PackIcon Kind="Plus" />
                        </Button>
                    </Grid>
                    
                    <!-- Add Customer Panel -->
                    <Grid Margin="0,10,0,0" Visibility="{Binding IsAddCustomerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="اسم العميل الجديد" Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="حفظ" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#8C52FF" Command="{Binding SaveNewCustomerCommand}"/>
                    </Grid>

                    <!-- Discount Panel -->
                    <Grid Margin="0,10,0,0" Visibility="{Binding IsDiscountVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="قيمة الخصم ($)" Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,15,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="المنتج" FontWeight="Bold" Foreground="#A0A0B0" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="1" Text="الكمية" FontWeight="Bold" Foreground="#A0A0B0" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="السعر" FontWeight="Bold" Foreground="#A0A0B0" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="الإجمالي" FontWeight="Bold" Foreground="#A0A0B0" HorizontalAlignment="Center"/>
                    </Grid>
                    <Separator Background="#2D2D42" Margin="0,0,0,10"/>
                </StackPanel>

                <!-- Cart Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProductName}" VerticalAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Right"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" FlowDirection="LeftToRight">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Padding="0" Width="20" Height="20" Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="MinusBox" Width="18" Height="18"/>
                                        </Button>
                                        <TextBlock Text="{Binding Quantity}" Margin="5,0" VerticalAlignment="Center"/>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Padding="0" Width="20" Height="20" Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="PlusBox" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat={}{0:N2}}" VerticalAlignment="Center" HorizontalAlignment="Center" FlowDirection="LeftToRight"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Subtotal, StringFormat={}{0:N2}}" VerticalAlignment="Center" HorizontalAlignment="Center" FlowDirection="LeftToRight"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Totals & Actions -->
                <StackPanel Grid.Row="2">
                    <Separator Background="#2D2D42" Margin="0,10"/>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="عدد الأصناف" Foreground="#A0A0B0" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalItems}" HorizontalAlignment="Left" FontWeight="Bold" FlowDirection="LeftToRight"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="الإجمالي" Foreground="#A0A0B0" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat={}{0:N2}}" HorizontalAlignment="Left" FontWeight="Bold" FlowDirection="LeftToRight"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="الخصم" Foreground="#A0A0B0" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="1" Text="{Binding Discount, StringFormat={}{0:N2}}" HorizontalAlignment="Left" FontWeight="Bold" Foreground="#4CAF50" FlowDirection="LeftToRight"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="الضريبة (15%)" Foreground="#A0A0B0" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="1" Text="{Binding Tax, StringFormat={}{0:N2}}" HorizontalAlignment="Left" FontWeight="Bold" FlowDirection="LeftToRight"/>
                    </Grid>
                    <Separator Background="#2D2D42" Margin="0,10"/>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="الإجمالي الكلي" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="1" Text="{Binding GrandTotal, StringFormat={}{0:N2}}" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold" Foreground="#8C52FF" FlowDirection="LeftToRight"/>
                    </Grid>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="تعليق الفاتورة" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#2196F3" BorderBrush="#2196F3" Margin="0,0,5,0" Padding="0"
                                Command="{Binding HoldInvoiceCommand}"/>
                        <Button Grid.Column="1" Content="إلغاء الفاتورة" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#FF5252" BorderBrush="#FF5252" Margin="5,0" Padding="0" 
                                Command="{Binding ClearCartCommand}"/>
                        <Button Grid.Column="2" Content="فاتورة جديدة" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#FFC107" BorderBrush="#FFC107" Margin="5,0,0,0" Padding="0"
                                Command="{Binding ClearCartCommand}"/>
                    </Grid>

                    <Button Margin="0,10,0,0" Background="#8C52FF" BorderBrush="#8C52FF" Foreground="White" Height="50" FontSize="18" FontWeight="Bold"
                            Command="{Binding CheckoutCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CashRegister" VerticalAlignment="Center" Width="24" Height="24" Margin="0,0,10,0"/>
                            <TextBlock Text="دفع" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding GrandTotal, StringFormat={}{0:N2}}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Side (which is right in RTL): Products Grid -->
        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search Bar -->
            <Border Grid.Row="0" Background="#1E1E2F" CornerRadius="10" Padding="15,5" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="BarcodeScan" Width="24" Height="24" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="البحث بالباركود أو اسم المنتج" BorderThickness="0" VerticalAlignment="Center" Foreground="White"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <!-- Categories -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,15">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}" 
                                    Margin="0,0,10,0" 
                                    Foreground="White" 
                                    BorderBrush="#2D2D42"
                                    Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Products -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="140" Height="140" Margin="5" Padding="0" Background="#1E1E2F" BorderBrush="#2D2D42"
                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ImageOutline" Width="50" Height="50" Foreground="#A0A0B0" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="120" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SalePrice, StringFormat={}{0:N2}}" Foreground="#8C52FF" TextAlignment="Center" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
